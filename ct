#!/bin/bash
# ct - Connect Tmux: wrapper around auto_fleet.sh
# Usage:
#   ct naga majores            - connect to listed servers
#   ct --save naga majores     - save server list and connect
#   ct --new naga majores      - create new sessions on servers with none
#   ct -r|--reload [...]       - kill local session, reload tmux config, reconnect
#   ct -u|--upgrade [...]      - force remote config sync on all servers
#   ct                         - reattach to last session, or load from saved list
#
# Remote config is normally pushed only when `git pull` detects local updates
# (or when -u is passed).  Nothing happens on the remote otherwise.
set -euo pipefail

AF_DIR="$HOME/.auto_fleet"
SAVED_SERVERS="$AF_DIR/servers"
SCRIPT="$AF_DIR/auto_fleet.sh"
LOCAL_SESSION="auto_fleet"
REPO_DIR="$HOME/.JProductive"

# Parse flags
SAVE=0
NEW=0
RELOAD=0
NO_UPDATE=0
UPGRADE=0
SERVERS=()
for arg in "$@"; do
  case "$arg" in
    --save) SAVE=1 ;;
    -n|--new) NEW=1 ;;
    -r|--reload) RELOAD=1 ;;
    -u|--upgrade) UPGRADE=1 ;;
    --no-update) NO_UPDATE=1 ;;
    *)      SERVERS+=("$arg") ;;
  esac
done

[ "$UPGRADE" -eq 1 ] && export CT_DO_REMOTE_SYNC=1

# Reload: kill local session, re-source tmux config so new bindings apply
if [ "$RELOAD" -eq 1 ]; then
  if tmux has-session -t "$LOCAL_SESSION" 2>/dev/null; then
    echo "Killing existing '$LOCAL_SESSION' session..."
    tmux kill-session -t "$LOCAL_SESSION"
  fi
  # Re-source tmux config in any remaining tmux server so new bindings take effect
  if tmux list-sessions 2>/dev/null | grep -q .; then
    TMUX_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"
    [ -f "$TMUX_CONF" ] || TMUX_CONF="$HOME/.tmux.conf"
    tmux source-file "$TMUX_CONF" 2>/dev/null && echo "Reloaded tmux config."
  fi
fi

# Self-update the ct toolkit from the repo (silent; best effort).
# If git pull advances HEAD, trigger remote sync too.
if [ "$NO_UPDATE" -eq 0 ] && [ -z "${CT_RESTARTED:-}" ] && [ -d "$REPO_DIR/.git" ]; then
  OLD_HEAD=$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null || echo "")
  if git -C "$REPO_DIR" pull --ff-only -q 2>/dev/null; then
    NEW_HEAD=$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null || echo "")
    if [ -n "$OLD_HEAD" ] && [ "$OLD_HEAD" != "$NEW_HEAD" ]; then
      echo "Local tools updated: ${OLD_HEAD:0:7} -> ${NEW_HEAD:0:7}"
      export CT_DO_REMOTE_SYNC=1
    fi
    for f in auto_fleet.sh fleet_monitor.sh ct_split.sh ct; do
      if [ -f "$REPO_DIR/$f" ] && ! cmp -s "$REPO_DIR/$f" "$AF_DIR/$f" 2>/dev/null; then
        cp -f "$REPO_DIR/$f" "$AF_DIR/$f"
        chmod +x "$AF_DIR/$f"
        # If ct itself was updated, re-exec so the new logic applies
        if [ "$f" = "ct" ]; then
          export CT_RESTARTED=1
          exec "$AF_DIR/ct" "$@"
        fi
      fi
    done
  fi
fi

# Save server list if requested
if [ "$SAVE" -eq 1 ]; then
  if [ ${#SERVERS[@]} -eq 0 ]; then
    echo "Error: --save requires at least one server name." >&2
    exit 1
  fi
  printf '%s\n' "${SERVERS[@]}" > "$SAVED_SERVERS"
  echo "Saved server list to $SAVED_SERVERS"
fi

# No servers given: try reattaching to existing session, then fall back to saved list
if [ ${#SERVERS[@]} -eq 0 ]; then
  if tmux has-session -t "$LOCAL_SESSION" 2>/dev/null; then
    echo "Reattaching to existing session..."
    tmux attach -t "$LOCAL_SESSION"
    exit 0
  fi
  if [ -f "$SAVED_SERVERS" ]; then
    mapfile -t SERVERS < <(grep -v '^[[:space:]]*$' "$SAVED_SERVERS")
  fi
  if [ ${#SERVERS[@]} -eq 0 ]; then
    echo "No existing session and no saved server list."
    echo "Usage: ct [--save] [--new] <server1> [server2] ..."
    exit 1
  fi
fi

ARGS=()
[ "$NEW" -eq 1 ] && ARGS+=("--new")
ARGS+=("${SERVERS[@]}")

exec bash "$SCRIPT" "${ARGS[@]}"
